<!DOCTYPE html>
<html>
<head>
    <title>Cyber Security Password Checker</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <style>
        body{
            margin:0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #000000, #001a00, #003300);
            color:#00ff99;
        }

        header{
            background:#000000;
            padding:15px;
            text-align:center;
            font-size:22px;
            font-weight:bold;
            color:#00ff99;
            border-bottom:2px solid #00ff99;
        }

        .main{
            display:flex;
            justify-content:center;
            align-items:center;
            padding:40px;
        }

        .container{
            width:380px;
            background:#0a0a0a;
            padding:25px;
            border-radius:12px;
            box-shadow:0 0 20px #00ff99;
            text-align:center;
            border:1px solid #00ff99;
        }

        h2{
            margin-bottom:10px;
            color:#00ff99;
        }

        input{
            width:100%;
            padding:10px;
            border-radius:6px;
            border:1px solid #00ff99;
            margin-top:10px;
            background:black;
            color:#00ff99;
            outline:none;
        }

        .toggle{
            margin-top:5px;
            font-size:13px;
            color:#00ff99;
            cursor:pointer;
        }

        .strength-bar{
            height:8px;
            background:#002200;
            border-radius:5px;
            margin-top:15px;
        }

        .strength{
            height:100%;
            width:0%;
            border-radius:5px;
            transition:0.4s;
        }

        #result{
            margin-top:10px;
            font-weight:bold;
        }

        .info-section{
            margin-top:20px;
            text-align:left;
            font-size:14px;
            color:#00ffcc;
        }

        .info-section ul{
            padding-left:18px;
        }

        footer{
            margin-top:25px;
            text-align:center;
            font-size:12px;
            color:#00ff99;
        }
    </style>
</head>

<body>

<header>
    🔐 Cyber Security Awareness
</header>

<div class="main">
<div class="container">

    <h2>Password Strength Checker</h2>
    <p>Check how secure your password is.</p>

    <input type="password" id="password" placeholder="Enter Password" onkeyup="checkStrength()">
    <div class="toggle" onclick="togglePassword()">Show / Hide Password</div>

    <div class="strength-bar">
        <div class="strength" id="strength"></div>
    </div>

    <p id="result"></p>

    <div class="info-section">
        <h4>Why Cyber Security is Important?</h4>
        <ul>
            <li>Protects personal data from hackers</li>
            <li>Prevents identity theft</li>
            <li>Secures online banking & payments</li>
            <li>Keeps social media accounts safe</li>
        </ul>

        <h4>Password Tips:</h4>
        <ul>
            <li>Use minimum 8 characters</li>
            <li>Include uppercase & lowercase letters</li>
            <li>Add numbers and special symbols</li>
            <li>Do not share passwords with anyone</li>
        </ul>
    </div>

</div>
</div>

<footer>
    Stay Safe Online | Cyber Security Project
</footer>

<script>

function checkStrength(){
    var password = document.getElementById("password").value;
    var strength = document.getElementById("strength");
    var result = document.getElementById("result");

    var score = 0;

    if(password.length >= 8) score++;
    if(password.match(/[A-Z]/)) score++;
    if(password.match(/[0-9]/)) score++;
    if(password.match(/[@$!%*?&]/)) score++;

    if(score <= 1){
        strength.style.width = "30%";
        strength.style.background = "red";
        result.innerHTML = "Weak Password";
        result.style.color = "red";
    }
    else if(score == 2 || score == 3){
        strength.style.width = "70%";
        strength.style.background = "orange";
        result.innerHTML = "Medium Password";
        result.style.color = "orange";
    }
    else{
        strength.style.width = "100%";
        strength.style.background = "#00ff99";
        result.innerHTML = "Strong Password";
        result.style.color = "#00ff99";
    }
}

function togglePassword(){
    var pass = document.getElementById("password");
    if(pass.type === "password"){
        pass.type = "text";
    } else {
        pass.type = "password";
    }
}

</script>

</body>
</html>

